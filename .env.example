APP_ENV=testing
APP_DEBUG=true
APP_KEY=
APP_THEME=pterodactyl
APP_TIMEZONE=UTC
APP_URL=http://localhost
APP_LOCALE=en
APP_ENVIRONMENT_ONLY=false

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=panel
DB_USERNAME=pterodactyl
DB_PASSWORD=

REDIS_HOST=localhost
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_DRIVER=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=array

HASHIDS_SALT=change_this_in_production
HASHIDS_LENGTH=8

MAIL_MAILER=log
MAIL_HOST=smtp.example.com
MAIL_PORT=25
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="Pterodactyl Panel"

APP_SERVICE_AUTHOR="example@example.com"
PTERODACTYL_TELEMETRY_ENABLED=false

# ---------------------------------------------------
# Captcha (Cloudflare Turnstile recommended)
# Providers: none, turnstile, hcaptcha, recaptcha
# ---------------------------------------------------
CAPTCHA_PROVIDER=none
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
CAPTCHA_LOGIN=true
CAPTCHA_FORGOT_PASSWORD=true
CAPTCHA_RESET_PASSWORD=true

# ---------------------------------------------------
# Asset hashing for cache-busting in production
# ---------------------------------------------------
PTERODACTYL_USE_ASSET_HASH=true
